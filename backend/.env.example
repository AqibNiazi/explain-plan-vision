# ExplainPlan-Vision — Environment variables
# Copy to .env and fill in values. Never commit .env to git.

# Hardware: auto | cuda | cpu
EP_DEVICE=auto

# Model assets — download from your Phase 1 Kaggle output
EP_CHECKPOINT_PATH=assets/best_model.pth
EP_CLASS_MAPPINGS_PATH=assets/class_mappings.json

# Inference thresholds
EP_SEVERITY_HIGH=0.85
EP_SEVERITY_MEDIUM=0.60
EP_CONFIDENCE_GATE=0.60

# Reasoning
EP_INFERENCE_DEPTH=3
EP_LOOKAHEAD_STEPS=4
EP_MEMORY_CAPACITY=20

# API
EP_DEBUG=false
EP_LOG_LEVEL=INFO
EP_API_PREFIX=/api/v1
EP_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Upload limits
EP_MAX_UPLOAD_MB=10
